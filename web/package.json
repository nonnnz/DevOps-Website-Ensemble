{
  "name": "thai-llm-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thai LLM portal and demo platform (SvelteKit + JavaScript). Mock + OpenAI-compatible inference ready for B200 / LANTA.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "setup": "prisma generate && prisma migrate dev --name init && node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "svelte": "^4.2.19",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@threlte/core": "^7.3.1",
    "@threlte/extras": "^8.12.1",
    "three": "^0.169.0"
  }
}
