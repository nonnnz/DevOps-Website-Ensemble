# ---------------------------------------------------------------------------
# Thai LLM Portal - environment configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit a real .env. Secrets (API keys) live ONLY here, never in the DB.
# ---------------------------------------------------------------------------

# PostgreSQL connection (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://thaillm:thaillm@localhost:5432/thaillm?schema=public"

# Inference mode: "mock" (no external API needed) or "real" (OpenAI-compatible endpoint)
LLM_API_MODE=mock

# OpenAI-compatible base URL used in real mode.
# The adapter calls: POST ${LLM_API_BASE_URL}/v1/chat/completions
# Examples: vLLM / TGI / Triton OpenAI front-ends running on B200 or LANTA.
LLM_API_BASE_URL=

# Secret API key for the inference endpoint. Server-only. Never exposed to the client.
LLM_API_KEY=

# Default model + backend used when the request / DB config does not specify one.
DEFAULT_MODEL_ID=thai-llm-chat-v0.1
DEFAULT_BACKEND=auto

# Optional per-backend endpoints. If set, these override LLM_API_BASE_URL for that backend.
B200_ENDPOINT_URL=
LANTA_ENDPOINT_URL=
# Local model server (models/serve_local.py). Set DEFAULT_BACKEND=local to use it.
LOCAL_ENDPOINT_URL=http://localhost:8000
# ModelHarbor swarm endpoint (uses /v1/completions). Set DEFAULT_BACKEND=modelharbor to use it.
MODELHARBOR_ENDPOINT_URL=http://swarm-manager.modelharbor.com:46120

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Admin token: gates /admin/* and write APIs (/api/config, /api/models).
# REQUIRED in production. If unset, admin is OPEN in dev and LOCKED in prod.
# Generate one: `openssl rand -hex 32`
ADMIN_TOKEN=

# SSRF guard: allow inference endpoints on private/loopback hosts.
# Must be "true" to use the local backend (http://localhost:8000) in dev.
# Leave unset/false in production so the API key can't be sent to internal IPs.
ALLOW_PRIVATE_ENDPOINTS=false

# Per-IP rate limit for write APIs per minute (reads get 4x this). Default 60.
RATE_LIMIT_PER_MINUTE=60

# Max accepted request body size in bytes (default 262144 = 256 KB).
MAX_REQUEST_BYTES=262144
